# Development Environment Configuration
# Copy this file to .env.development.local and update with your local values

# Supabase Configuration (Local Development)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_local_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_local_service_role_key_here
SUPABASE_PROJECT_REF=local

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TeamGrid Development

# Email Configuration (Development)
RESEND_API_KEY=re_xxxxxxxxxxxx_development_key
EMAIL_FROM=noreply@dev.teamgrid.app

# Monitoring & Analytics (Development)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx_development
SENTRY_AUTH_TOKEN=your_sentry_auth_token_development

# Redis Configuration (Development)
UPSTASH_REDIS_REST_URL=https://your-redis-dev.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_development

# OAuth Providers (Development - Optional)
# Note: For local development, you may use test OAuth credentials
# or use Supabase's built-in email/password auth

# Google OAuth (Development)
GOOGLE_CLIENT_ID=your_google_client_id_for_dev
GOOGLE_CLIENT_SECRET=your_google_client_secret_for_dev

# GitHub OAuth (Development)
GITHUB_CLIENT_ID=your_github_client_id_for_dev
GITHUB_CLIENT_SECRET=your_github_client_secret_for_dev

# LinkedIn OAuth (Development)
LINKEDIN_CLIENT_ID=your_linkedin_client_id_for_dev
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_for_dev

# Development Features
NEXT_PUBLIC_ENABLE_DEBUG=true
NEXT_PUBLIC_ENABLE_MOCK_DATA=true