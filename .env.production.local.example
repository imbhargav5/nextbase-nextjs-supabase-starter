# Production Environment Configuration
# Copy this file to .env.production.local and update with your production values

# Supabase Configuration (Production)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_production_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_production_service_role_key_here
SUPABASE_PROJECT_REF=your_production_project_ref_here

# Application Configuration
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=TeamGrid

# Email Configuration (Production)
RESEND_API_KEY=re_xxxxxxxxxxxx_production_key
EMAIL_FROM=noreply@your-domain.com

# Monitoring & Analytics (Production)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx_production
SENTRY_AUTH_TOKEN=your_sentry_auth_token_production

# Redis Configuration (Production)
UPSTASH_REDIS_REST_URL=https://your-redis-production.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_production

# OAuth Providers (Production)
# Configure these in Supabase Dashboard under Authentication → Providers

# Google OAuth (Production)
GOOGLE_CLIENT_ID=your_google_client_id_for_production
GOOGLE_CLIENT_SECRET=your_google_client_secret_for_production

# GitHub OAuth (Production)
GITHUB_CLIENT_ID=your_github_client_id_for_production
GITHUB_CLIENT_SECRET=your_github_client_secret_for_production

# LinkedIn OAuth (Production)
LINKEDIN_CLIENT_ID=your_linkedin_client_id_for_production
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_for_production

# Production Features
NEXT_PUBLIC_ENABLE_DEBUG=false
NEXT_PUBLIC_ENABLE_MOCK_DATA=false

# Security Configuration
NEXT_PUBLIC_CSP_ENABLED=true
NEXT_PUBLIC_HELMET_ENABLED=true

# Performance Configuration
NEXT_PUBLIC_CACHE_TTL=3600
NEXT_PUBLIC_RATE_LIMIT_REQUESTS=100
NEXT_PUBLIC_RATE_LIMIT_WINDOW=900

# CDN Configuration (if using)
NEXT_PUBLIC_CDN_URL=https://cdn.your-domain.com
NEXT_PUBLIC_ASSETS_BUCKET=your-assets-bucket

# Backup Configuration
NEXT_PUBLIC_BACKUP_ENABLED=true
NEXT_PUBLIC_BACKUP_SCHEDULE="0 2 * * *"
NEXT_PUBLIC_BACKUP_RETENTION_DAYS=30