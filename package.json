{
  "name": "nextbase-nextjs-supabase-starter",
  "private": true,
  "version": "2.2.0",
  "packageManager": "pnpm@9.0.6+sha512.f6d863130973207cb7a336d6b439a242a26ac8068077df530d6a86069419853dc1ffe64029ec594a9c505a3a410d19643c870aba6776330f5cfddcf10a9c1617",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "web#dev": "turbo run dev --filter=web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "gen-types": "turbo run gen-types --filter=database",
    "gen-types-local": "turbo run gen-types-local --filter=database",
    "database#start": "turbo run database#start",
    "database#stop": "turbo run database#stop",
    "database#status": "turbo run database#status",
    "test:e2e": "turbo run test:e2e --filter=web",
    "supabase:sync-env": "tsx scripts/sync-supabase-env.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status",
    "release:github": "node scripts/release-github.mjs"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.30.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tsx": "^4.19.2",
    "turbo": "^2.2.3"
  }
}
